{
  "name": "letterlink",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:codex": "vite --host 0.0.0.0 --port 4173 --strictPort",
    "build": "tsc -b && vite build && cp dist/index.html dist/404.html",
